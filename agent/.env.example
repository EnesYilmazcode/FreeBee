# Copy this file to `.env` (same folder) and paste your key in.
# `.env` is git-ignored, so your key never gets committed.

# Google Gemini (what we're using for the runtime bee):
GOOGLE_API_KEY=your-gemini-key-here

# Optional alternatives (only need ONE key total):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
